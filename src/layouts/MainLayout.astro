---
// src/layouts/MainLayout.astro
const { title } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <nav style="padding: 1rem; border-bottom: 1px solid #ccc;">
      <a href="/">首页</a> | <a href="/about">关于我们</a>
    </nav>
    
    <main style="padding: 1rem;">
      <slot />
    </main>

    <footer style="padding: 1rem; border-top: 1px solid #ccc; text-align: center;">
      <p>© 2026 你的公司名称</p>
    </footer>
  </body>
</html>