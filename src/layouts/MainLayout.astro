---
interface Props {
  title: string;
}
const { title } = Astro.props;
const pathname = Astro.url.pathname;
---

<html lang="zh-CN" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">
    
    <style is:global>
      @import "tailwindcss";

      body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        display: grid;
        grid-template-rows: auto 1fr auto;
        font-family: 'Noto Sans SC', sans-serif;
        background-color: #f9fafb;
        color: #1f2937;
      }

      /* 核心：防崩布局滚动条方案 */
      .hover-scrollbar {
        overflow-x: auto;
        scrollbar-width: none; /* Firefox */
      }
      
      .hover-scrollbar::-webkit-scrollbar {
        height: 8px;
        background: transparent;
      }

      .hover-scrollbar::-webkit-scrollbar-thumb {
        background: transparent;
        border-radius: 4px;
        transition: background 0.3s;
      }

      .hover-scrollbar:hover::-webkit-scrollbar-thumb {
        background: #cbd5e1;
      }
    </style>
  </head>

  <body>
    <nav class="bg-white border-b border-gray-200">
      <div style="max-width: 1280px; margin: 0 auto; padding: 20px 40px; display: flex; justify-content: space-between; align-items: center;">
        <span class="text-xl font-bold tracking-tight text-indigo-600">元智教育</span>
        <div class="flex items-center gap-6 font-medium">
          <a href="/" class={`px-4 py-2 rounded-lg transition border ${pathname === '/' ? 'border-gray-300 bg-gray-50' : 'border-transparent'}`}>首页</a>
          <a href="/projects" class="px-4 py-2 rounded-lg transition border border-transparent">项目</a>
          <a href="/contact" class="px-4 py-2 rounded-lg transition border border-transparent">联系我们</a>
        </div>
      </div>
    </nav>

    <main style="max-width: 1280px; width: 100%; margin: 0 auto; padding: 40px;">
      <slot />
    </main>

    <footer class="bg-gray-50 border-t border-gray-200">
      <div style="max-width: 1280px; margin: 0 auto; padding: 20px; text-align: center; color: #6b7280; font-size: 0.875rem;">
        &copy; 2026 Puffy-Proxima Company. All rights reserved.
      </div>
    </footer>
  </body>
</html>