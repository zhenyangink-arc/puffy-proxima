---
import MainLayout from "../layouts/MainLayout.astro";
import AppIcon from "../layouts/AppIcon.astro";

---

<MainLayout title="Puffy-Proxima | 首页">
  <section
    class="relative w-full pt-20 pb-20 flex flex-col items-center text-center overflow-hidden bg-white border-b border-gray-50"
  >
    <!-- 左下角书本图标 -->
    <div
      class="absolute bottom-8 left-4 md:left-12 transform -rotate-12 bg-amber-50/60 border-2 border-gray-900 p-4 rounded-2xl shadow-sm hidden sm:flex items-end gap-1 select-none animate-pulse"
    >
      <AppIcon name="book" size={40} color="#d97706" />

      <div
        class="w-6 h-6 rounded-full bg-gray-900 border-2 border-amber-50 flex items-center justify-center shadow-sm"
      >
        <AppIcon
          name="check"
          size={16}
          color="#34d399"
          strokeWidth={3}
        />
      </div>
    </div>

    <!-- 右下角毕业帽图标 -->
    <div
      class="absolute bottom-12 right-4 md:right-12 transform rotate-12 bg-purple-50/60 border-2 border-gray-900 p-4 rounded-2xl shadow-sm hidden sm:flex flex-col items-center select-none"
    >
      <div class="flex items-center justify-center gap-1">
        <AppIcon name="sparkles" size={13} color="#a855f7" />

        <AppIcon
          name="graduation"
          size={40}
          color="#7e22ce"
          strokeWidth={2.2}
        />

        <AppIcon name="sparkles" size={13} color="#a855f7" />
      </div>
    </div>

    <div class="max-w-4xl w-full flex flex-col items-center px-4 z-10">
      <!-- 顶部五个 SVG 图标 -->
      <div class="flex items-center gap-8 mb-10">
        <div
          class="w-14 h-14 rounded-full bg-amber-50 border-2 border-gray-950 flex items-center justify-center shadow-sm transform -rotate-6 select-none"
        >
          <AppIcon name="code" size={28} color="#d97706" />
        </div>

        <div
          class="w-14 h-14 rounded-full bg-blue-50 border-2 border-gray-950 flex items-center justify-center shadow-sm transform rotate-3 select-none"
        >
          <AppIcon name="book" size={28} color="#2563eb" />
        </div>

        <div
          class="w-14 h-14 rounded-full bg-emerald-50 border-2 border-gray-950 flex items-center justify-center shadow-sm transform -rotate-3 select-none"
        >
          <AppIcon name="bot" size={28} color="#059669" />
        </div>

        <div
          class="w-14 h-14 rounded-full bg-purple-50 border-2 border-gray-950 flex items-center justify-center shadow-sm transform rotate-6 select-none"
        >
          <AppIcon name="file" size={28} color="#9333ea" />
        </div>

        <div
          class="w-14 h-14 rounded-full bg-rose-50 border-2 border-gray-950 flex items-center justify-center shadow-sm transform -rotate-12 select-none"
        >
          <AppIcon name="map" size={28} color="#e11d48" />
        </div>
      </div>

      <h1
        class="text-4xl sm:text-5xl md:text-6xl font-black text-gray-900 tracking-tighter mb-6 leading-tight max-w-3xl"
      >
        韩国留学，从精准规划开始

        <span
          class="inline-flex items-center gap-2 px-5 py-2 bg-indigo-50 text-indigo-600 rounded-3xl mt-2 border border-indigo-100 shadow-inner"
        >
          <span class="w-3 h-3 rounded-full bg-indigo-500 animate-ping"></span>
          探索韩国留学的更多可能
        </span>
      </h1>

      <p
        class="text-lg md:text-xl text-gray-600 font-medium max-w-2xl leading-relaxed mt-4"
      >
        从院校选择、专业规划到语言提升、申请指导，借助专家分析和 AI 智能学习，为您打造一站式韩国留学成长平台
      </p>

      <div class="flex flex-wrap justify-center gap-x-10 gap-y-6" 
           style="margin-top: 20px">
        <a
          href="#"
          class="bg-indigo-600 text-white px-8 py-3.5 rounded-xl font-bold hover:bg-indigo-700 transition shadow-lg shadow-indigo-100 text-base"
        >
          免费开始使用
        </a>

        <a
          href="#"
          class="bg-gray-50 border border-gray-200 text-gray-700 px-8 py-3.5 rounded-xl font-bold hover:bg-gray-100 transition text-base"
        >
          预约演示查看
        </a>
      </div>
    </div>
  </section>


  <div class="py-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

      <div
        class="col-span-8 min-w-0 h-[400px] relative rounded-3xl overflow-hidden shadow-sm "
      >
        <div
          id="carousel"
          class="flex h-full w-full overflow-x-auto snap-x snap-mandatory scroll-smooth hover-scrollbar "
        >
          <div
            class="w-full h-full flex-shrink-0 snap-center bg-gradient-to-br from-indigo-600 to-blue-700 flex flex-col justify-center items-center text-white p-10"
          >
            <h2 class="text-4xl font-bold mb-4">打造你的数字疆域</h2>
            <p class="text-indigo-100 text-lg">
              融合高性能架构与现代美学
            </p>
          </div>

          <div
            class="w-full h-full flex-shrink-0 snap-center bg-gradient-to-br from-emerald-500 to-teal-600 flex flex-col justify-center items-center text-white p-10"
          >
            <h2 class="text-4xl font-bold mb-4">智能教育解决方案</h2>
            <p class="text-emerald-50 text-lg">
              通过 AI 技术精准提升教学效率
            </p>
          </div>

          <div
            class="w-full h-full flex-shrink-0 snap-center bg-gradient-to-br from-rose-500 to-pink-600 flex flex-col justify-center items-center text-white p-10"
          >
            <h2 class="text-4xl font-bold mb-4">学习路线规划</h2>
            <p class="text-rose-50 text-lg">
              为你量身定制的成长路径
            </p>
          </div>
        </div>

        <button
          id="prevButton"
          type="button"
          aria-label="上一张"
          class="absolute left-5 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-black/20 text-4xl leading-none text-white backdrop-blur-sm transition hover:bg-black/40 focus:outline-none focus:ring-2 focus:ring-white/80"
        >
          ‹
        </button>

        <button
          id="nextButton"
          type="button"
          aria-label="下一张"
          class="absolute right-5 top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-black/20 text-4xl leading-none text-white backdrop-blur-sm transition hover:bg-black/40 focus:outline-none focus:ring-2 focus:ring-white/80"
        >
          ›
        </button>

        <div class="absolute bottom-5 left-1/2 z-10 flex -translate-x-1/2 gap-2">
          <button
            type="button"
            class="carousel-dot h-2.5 w-2.5 rounded-full bg-white transition hover:scale-110"
            data-slide="0"
            aria-label="跳转到第 1 张"
          ></button>

          <button
            type="button"
            class="carousel-dot h-2.5 w-2.5 rounded-full bg-white/50 transition hover:scale-110"
            data-slide="1"
            aria-label="跳转到第 2 张"
          ></button>

          <button
            type="button"
            class="carousel-dot h-2.5 w-2.5 rounded-full bg-white/50 transition hover:scale-110"
            data-slide="2"
            aria-label="跳转到第 3 张"
          ></button>
        </div>
      </div>

      <div class="lg:col-span-4 flex flex-col gap-4 w-full">
        <div class="font-bold text-gray-900 text-lg mb-1">常用服务</div>

        <a
          href="#"
          class="group flex items-center justify-between py-10 px-8 bg-white border border-gray-100 rounded-3xl shadow-sm hover:border-indigo-300 hover:shadow-lg transition-all duration-300 w-full"
        >
          <div class="flex items-center gap-6">
            <div
              class="w-16 h-16 rounded-2xl bg-indigo-50 flex items-center justify-center text-indigo-600 shrink-0"
            >
              <span class="text-3xl">📝</span>
            </div>

            <span
              class="font-bold text-gray-800 group-hover:text-indigo-900 transition-colors text-2xl"
            >
              한국어 진단평가
            </span>
          </div>

          <span
            class="text-gray-400 group-hover:text-indigo-500 transition-colors text-3xl"
          >
            →
          </span>
        </a>

        <a
          href="#"
          class="group flex items-center justify-between py-10 px-8 bg-white border border-gray-100 rounded-3xl shadow-sm hover:border-indigo-300 hover:shadow-lg transition-all duration-300 w-full"
        >
          <div class="flex items-center gap-6">
            <div
              class="w-16 h-16 rounded-2xl bg-indigo-50 flex items-center justify-center text-indigo-600 shrink-0"
            >
              <span class="text-3xl">📚</span>
            </div>

            <span
              class="font-bold text-gray-800 group-hover:text-indigo-900 transition-colors text-2xl"
            >
              세종학당 전자도서관
            </span>
          </div>

          <span
            class="text-gray-400 group-hover:text-indigo-500 transition-colors text-3xl"
          >
            →
          </span>
        </a>

        <a
          href="#"
          class="group flex items-center justify-between py-10 px-8 bg-white border border-gray-100 rounded-3xl shadow-sm hover:border-indigo-300 hover:shadow-lg transition-all duration-300 w-full"
        >
          <div class="flex items-center gap-6">
            <div
              class="w-16 h-16 rounded-2xl bg-indigo-50 flex items-center justify-center text-indigo-600 shrink-0"
            >
              <span class="text-3xl">🗺️</span>
            </div>

            <span
              class="font-bold text-gray-800 group-hover:text-indigo-900 transition-colors text-2xl"
            >
              학습 로드맵
            </span>
          </div>

          <span
            class="text-gray-400 group-hover:text-indigo-500 transition-colors text-3xl"
          >
            →
          </span>
        </a>
      </div>
    </div>
  </div>

  <section class="py-12 border-t border-gray-200">
    <h3 class="text-2xl font-bold text-center mb-10">
      为什么选择 Puffy-Proxima?
    </h3>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div
        class="bg-white p-8 rounded-3xl border shadow-sm min-h-[200px] flex items-center justify-center hover:shadow-md transition"
      >
        ⚡ 高性能计算核心
      </div>

      <div
        class="bg-white p-8 rounded-3xl border shadow-sm min-h-[200px] flex items-center justify-center hover:shadow-md transition"
      >
        🎨 极简美学设计
      </div>

      <div
        class="bg-white p-8 rounded-3xl border shadow-sm min-h-[200px] flex items-center justify-center hover:shadow-md transition"
      >
        🎧 24/7 专业支持
      </div>

      <div
        class="bg-white p-8 rounded-3xl border shadow-sm min-h-[200px] flex items-center justify-center hover:shadow-md transition"
      >
        🚀 快速部署服务
      </div>
    </div>
  </section>

  <section class="py-16 w-full flex justify-center">
    <div
      class="bg-white p-12 rounded-3xl border border-gray-100 shadow-sm text-center max-w-3xl w-full mx-4"
    >
      <h3 class="text-3xl font-bold mb-4 text-gray-900">
        有疑问？向 AI 提问
      </h3>

      <p class="text-gray-600 mb-10 text-lg">
        Puffy-Proxima 智能助手随时为你解答关于 learning、项目或技术的任何问题。
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-[1fr,auto] gap-4">
        <input
          type="text"
          placeholder="例如：如何开始韩语学习..."
          class="w-full px-8 py-5 rounded-2xl border border-gray-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition-all text-lg"
        />

        <button
          class="px-10 py-5 bg-indigo-600 text-white font-bold rounded-2xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-100 text-lg whitespace-nowrap"
        >
          开始询问
        </button>
      </div>
    </div>
  </section>

  <script>
  const carousel = document.getElementById("carousel") as HTMLDivElement | null;
  const prevButton = document.getElementById("prevButton") as HTMLButtonElement | null;
  const nextButton = document.getElementById("nextButton") as HTMLButtonElement | null;
  const dots = document.querySelectorAll<HTMLButtonElement>(".carousel-dot");

  let currentSlide: number = 0;
  let autoPlayTimer: number | undefined;

  function getSlideWidth(): number {
    return carousel ? carousel.clientWidth : 0;
  }

  function updateDots(): void {
    dots.forEach((dot, dotIndex) => {
      if (dotIndex === currentSlide) {
        dot.classList.remove("bg-white/50");
        dot.classList.add("bg-white");
      } else {
        dot.classList.remove("bg-white");
        dot.classList.add("bg-white/50");
      }
    });
  }

  function goToSlide(index: number): void {
    if (!carousel) return;

    const totalSlides: number = 3;

    if (index < 0) {
      currentSlide = totalSlides - 1;
    } else if (index >= totalSlides) {
      currentSlide = 0;
    } else {
      currentSlide = index;
    }

    carousel.scrollTo({
      left: getSlideWidth() * currentSlide,
      behavior: "smooth"
    });

    updateDots();
  }

  function stopAutoPlay(): void {
    if (autoPlayTimer !== undefined) {
      window.clearInterval(autoPlayTimer);
      autoPlayTimer = undefined;
    }
  }

  function startAutoPlay(): void {
    stopAutoPlay();

    autoPlayTimer = window.setInterval(() => {
      goToSlide(currentSlide + 1);
    }, 3000);
  }

  prevButton?.addEventListener("click", () => {
    goToSlide(currentSlide - 1);
    startAutoPlay();
  });

  nextButton?.addEventListener("click", () => {
    goToSlide(currentSlide + 1);
    startAutoPlay();
  });

  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      const targetSlide: number = Number(dot.dataset.slide);
      goToSlide(targetSlide);
      startAutoPlay();
    });
  });

  carousel?.addEventListener("mouseenter", stopAutoPlay);
  carousel?.addEventListener("mouseleave", startAutoPlay);

  window.addEventListener("resize", () => {
    if (!carousel) return;

    carousel.scrollTo({
      left: getSlideWidth() * currentSlide,
      behavior: "auto"
    });
  });

  updateDots();
  startAutoPlay();
</script>
</MainLayout>